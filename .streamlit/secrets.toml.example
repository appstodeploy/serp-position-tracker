# Copy to .streamlit/secrets.toml for local use, OR paste these into the
# Streamlit Community Cloud "Secrets" manager (App → Settings → Secrets).
# This file (the .example) is safe to commit; secrets.toml is git-ignored.

# Password required to open the app (the gate on every page).
app_password = "change-me-to-a-strong-password"

# Optional: a default Serper key for YOUR session only (leave unset for
# multi-user, where each visitor enters their own key).
# SERPER_API_KEY = "your_serper_key"
