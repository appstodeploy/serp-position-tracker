# Copy to .streamlit/secrets.toml for local use, OR paste these into the
# Streamlit Community Cloud "Secrets" manager (App → Settings → Secrets).
# This file (the .example) is safe to commit; secrets.toml is git-ignored.

# Password required to open the app (the gate on every page).
app_password = "change-me-to-a-strong-password"

# Optional: a default Serper key for YOUR session only (leave unset for
# multi-user, where each visitor enters their own key).
# SERPER_API_KEY = "your_serper_key"

# ----------------------------------------------------------------------------
# Optional: durable result storage in Google Sheets (recommended for large runs
# of thousands of queries). Streamlit Cloud's disk is wiped on every reboot;
# with this configured, results stream to a Google Sheet you own and survive any
# restart. Setup: create a Google Cloud service account, enable the Google
# Sheets API + Drive API, download its JSON key, create a blank Google Sheet and
# share it as Editor with the service account's client_email, then fill in below.
# ----------------------------------------------------------------------------
# gsheet_id = "the-id-between /d/ and /edit in your sheet URL"
#
# [gcp_service_account]
# type = "service_account"
# project_id = "your-project-id"
# private_key_id = "..."
# private_key = "-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# client_email = "name@your-project.iam.gserviceaccount.com"
# client_id = "..."
# auth_uri = "https://accounts.google.com/o/oauth2/auth"
# token_uri = "https://oauth2.googleapis.com/token"
# auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
# client_x509_cert_url = "..."
